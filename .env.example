# HTTP port
HTTP_PORT=80

# HTTPS port
HTTPS_PORT=443

# Certbot certificate files (absolute paths recommended)
TLS_KEY_PATH=/etc/letsencrypt/live/your-domain/privkey.pem
TLS_CERT_PATH=/etc/letsencrypt/live/your-domain/fullchain.pem
# Optional intermediate chain file
# TLS_CHAIN_PATH=/etc/letsencrypt/live/your-domain/chain.pem
